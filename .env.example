# ── Server ────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info                     # debug | info | warning | error

# ── MCP ───────────────────────────────────────────────
MCP_SERVER_NAME=mcp-server-template
MCP_MOUNT_PATH=/mcp                # path where FastMCP is mounted on FastAPI

# ── Auth ──────────────────────────────────────────────
AUTH_MODE=api_key                  # api_key | oauth2 | none (for local dev only)

# API Key mode
API_KEYS=["sk-dev-key-1"]         # JSON list of valid keys

# OAuth2 Client Credentials mode
OAUTH2_TOKEN_URL=https://example.com/oauth/token
OAUTH2_JWKS_URL=https://example.com/.well-known/jwks.json
OAUTH2_AUDIENCE=https://my-mcp-server
OAUTH2_ISSUER=https://example.com

# ── CORS ──────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000"]  # Uncomment to enable CORS

# ── Langfuse ──────────────────────────────────────────
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://langfuse:3000  # or your hosted instance

# ── Wiki.js ───────────────────────────────────────────
WIKIJS_URL=http://wiki:3000          # Docker service name + port of your Wiki.js instance
WIKIJS_API_TOKEN=                    # Token from Wiki.js Admin > API Access

# ── SQL Server ────────────────────────────────────────
# Named connections as JSON — add as many as needed.
# Each entry maps a connection name to its credentials.
# "driver" and "trust_server_certificate" are optional (see defaults in SqlConnectionConfig).
SQL_CONNECTIONS={"default": {"host": "your-server.database.windows.net", "database": "your_db", "username": "your_user", "password": "your_password"}, "readonly": {"host": "your-server.database.windows.net", "database": "your_db", "username": "ro_user", "password": "ro_password"}}
SQL_DEFAULT_CONNECTION=default

# ── Azure Blob Storage ────────────────────────────────
# Default container used by blob_list / blob_get_content / blob_query_parquet when no container is passed.
# blob_query_parquet: reference files as read_parquet('azure://{container}/{path}')
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=my-container
AZURE_BLOB_METADATA_PREFIX=                # optional prefix for SQL metadata .md files, e.g. "tables/"

# ── Baserow ───────────────────────────────────────────
BASEROW_URL=http://baserow
BASEROW_TOKEN=

# ── Prefect ───────────────────────────────────────────
PREFECT_URL=http://prefect-server:4200/api  # Docker service name + port of your Prefect instance
PREFECT_API_KEY=                            # Optional — leave empty for open self-hosted instances
PREFECT_NETWORK=prefect_default             # Docker network name of your Prefect compose stack
