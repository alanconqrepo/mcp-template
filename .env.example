# ── Server ────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info                     # debug | info | warning | error

# ── MCP ───────────────────────────────────────────────
MCP_SERVER_NAME=mcp-server-template
MCP_MOUNT_PATH=/mcp                # path where FastMCP is mounted on FastAPI

# ── Auth ──────────────────────────────────────────────
AUTH_MODE=api_key                  # api_key | oauth2 | none (for local dev only)

# API Key mode
API_KEYS=["sk-dev-key-1"]         # JSON list of valid keys

# OAuth2 Client Credentials mode
OAUTH2_TOKEN_URL=https://example.com/oauth/token
OAUTH2_JWKS_URL=https://example.com/.well-known/jwks.json
OAUTH2_AUDIENCE=https://my-mcp-server
OAUTH2_ISSUER=https://example.com

# ── CORS ──────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000"]  # Uncomment to enable CORS

# ── Langfuse ──────────────────────────────────────────
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://langfuse:3000  # or your hosted instance

# ── Wiki.js ───────────────────────────────────────────
WIKIJS_URL=http://wiki:3000          # Docker service name + port of your Wiki.js instance
WIKIJS_API_TOKEN=                    # Token from Wiki.js Admin > API Access
WIKIJS_NETWORK=wikijs_default        # Docker network name of your Wiki.js compose stack

# ── Outline ───────────────────────────────────────────
OUTLINE_URL=http://outline:3000      # Docker service name + port de votre instance Outline
OUTLINE_API_TOKEN=                   # Token depuis Outline Settings > API > Create token
OUTLINE_NETWORK=outline_default      # Nom du réseau Docker de votre stack Outline

# ── SQL Server ────────────────────────────────────────
# Named connections as JSON — add as many as needed.
# Each entry maps a connection name to its credentials.
# "driver" and "trust_server_certificate" are optional (see defaults in SqlConnectionConfig).
SQL_CONNECTIONS={"default": {"host": "your-server.database.windows.net", "database": "your_db", "username": "your_user", "password": "your_password"}, "readonly": {"host": "your-server.database.windows.net", "database": "your_db", "username": "ro_user", "password": "ro_password"}}
SQL_DEFAULT_CONNECTION=default

# ── Azure Blob Storage ────────────────────────────────
# Default container used by blob_list / blob_get_content / blob_query_parquet when no container is passed.
# blob_query_parquet: reference files as read_parquet('azure://{container}/{path}')
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=my-container
AZURE_BLOB_METADATA_PREFIX=                # optional prefix for SQL metadata .md files, e.g. "tables/"

# ── Baserow ───────────────────────────────────────────
BASEROW_URL=http://baserow
BASEROW_TOKEN=

# ── Prefect ───────────────────────────────────────────
PREFECT_URL=http://prefect-server:4200/api  # Docker service name + port of your Prefect instance
PREFECT_API_KEY=                            # Optional — leave empty for open self-hosted instances
PREFECT_NETWORK=prefect_default             # Docker network name of your Prefect compose stack

# ── DeepL Translation ─────────────────────────────────
DEEPL_API_KEY=                             # DeepL Auth Key (clés Free se terminent par :fx)
DEEPL_BLOB_CONTAINER=deepl-documents       # Container Azure pour les documents I/O
DEEPL_BLOB_OUTPUT_PREFIX=deepl/translated/ # Préfixe des blobs de sortie (trailing slash requis)

# ── DocuWare ──────────────────────────────────────────
# Shared service account — MCP API keys control per-user access.
# The service account must have read/write rights on the target cabinets.
DOCUWARE_URL=https://docuware.mycompany.com
DOCUWARE_USERNAME=svc-mcp
DOCUWARE_PASSWORD=
DOCUWARE_ORGANIZATION=MyOrg               # Organization name as shown in DocuWare Admin
DOCUWARE_BLOB_PREFIX=docuware/            # Blob prefix for files downloaded from DocuWare

# ── Azure DevOps ──────────────────────────────────────
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/myorg   # URL de l'organisation Azure DevOps
AZURE_DEVOPS_DEFAULT_PROJECT=                       # Projet par défaut (optionnel)
AZURE_DEVOPS_DEFAULT_PAT=                           # PAT de fallback (compte de service, optionnel)

# ── Anthropic Agent ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # API key for the run_agent MCP tool

# ── OpenWebUI (agent-to-agent) ────────────────────────
# Permet d'appeler un autre modèle OpenWebUI depuis une session MCP (orchestration multi-agent).
# L'API key est celle d'un compte admin/service — un seul compte pour tous les utilisateurs.
OPENWEBUI_URL=http://openwebui:3000         # URL interne Docker ou URL publique
OPENWEBUI_API_KEY=sk-owui-...              # Profil > Paramètres > API Keys dans OpenWebUI
OPENWEBUI_TIMEOUT=120                      # Secondes (les LLM peuvent être lents)

# ── Vector Store (PostgreSQL + pgvector) ─────────────
# DSN d'un serveur PostgreSQL avec l'extension pgvector installée.
# Docker : pgvector/pgvector:pg16 — image officielle avec pgvector préinstallé.
PGVECTOR_DSN=postgresql://user:password@localhost:5432/vectordb
PGVECTOR_POOL_MIN_SIZE=2
PGVECTOR_POOL_MAX_SIZE=10

# ── Embedding API (OpenAI-compatible) ─────────────────
# Compatible : OpenAI, Azure OpenAI, Ollama (/v1/embeddings), LM Studio, etc.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536        # doit correspondre au modèle — fixé à la création de la collection
EMBEDDING_BATCH_SIZE=100         # nombre de textes par appel API (coût / rate limit)
EMBEDDING_TIMEOUT=30             # secondes

# ── Apify ─────────────────────────────────────────────
APIFY_API_TOKEN=                           # Token API Apify (https://console.apify.com/account/integrations)

# Actor IDs LinkedIn — remplacer si un actor est déprécié ou si vous préférez une alternative
APIFY_ACTOR_COMPANY_INFO=scrapier/linkedin-company-scraper-actor
APIFY_ACTOR_COMPANY_POSTS=automation-lab/linkedin-company-posts-scraper
APIFY_ACTOR_SEARCH_COMPANIES=bebity/linkedin-premium-actor
APIFY_ACTOR_SEARCH_PEOPLE=harvestapi/linkedin-profile-search
APIFY_ACTOR_PERSON_PROFILE=curious_coder/linkedin-profile-scraper
APIFY_ACTOR_SEND_MESSAGE=curious_coder/linkedin-message-sender

# ── LinkedIn ──────────────────────────────────────────
# Cookie de session LinkedIn requis uniquement pour linkedin_send_message.
# Obtenir : navigateur > DevTools > Application > Cookies > linkedin.com > li_at
LINKEDIN_LI_AT=
